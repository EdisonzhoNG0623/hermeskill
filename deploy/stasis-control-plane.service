[Unit]
Description=Stasis Control Plane (FastAPI)
After=network-online.target postgresql.service
Wants=network-online.target postgresql.service

[Service]
Type=simple
User=stasis
Group=stasis
WorkingDirectory=/opt/stasis
ExecStart=/opt/stasis/.venv/bin/stasis-control-plane
Restart=on-failure
RestartSec=3
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/opt/stasis
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
